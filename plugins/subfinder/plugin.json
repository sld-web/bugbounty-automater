{
  "name": "subfinder",
  "version": "1.0",
  "permission_level": "SAFE",
  "description": "Passive subdomain discovery using Subfinder",
  "inputs": {
    "target": {
      "name": "target",
      "type": "string",
      "required": true,
      "description": "Target domain"
    },
    "sources": {
      "name": "sources",
      "type": "array",
      "required": false,
      "description": "Specific sources to use"
    },
    "all": {
      "name": "all",
      "type": "boolean",
      "default": true,
      "description": "Use all sources"
    }
  },
  "outputs": {
    "subdomains": {
      "name": "subdomains",
      "type": "json_file",
      "description": "List of discovered subdomains"
    }
  },
  "timeout_seconds": 600,
  "docker_image": "bugbounty-subfinder:latest",
  "entrypoint": "python /app/run.py"
}
