# Database
DATABASE_URL=postgresql+asyncpg://bugbounty:bugbounty@localhost:5432/bugbounty_db
DATABASE_URL_SYNC=postgresql://bugbounty:bugbounty@localhost:5432/bugbounty_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Application
APP_NAME=BugBounty Automator
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# Backend Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173

# External APIs
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Intelligence APIs
SHODAN_API_KEY=YOUR_SHODAN_API_KEY
CENSYS_API_ID=YOUR_CENSYS_API_ID
CENSYS_API_SECRET=YOUR_CENSYS_API_SECRET
NVD_API_KEY=YOUR_NVD_API_KEY
GITHUB_TOKEN=YOUR_GITHUB_TOKEN
VIRUSTOTAL_API_KEY=YOUR_VIRUSTOTAL_API_KEY
ALIENVAULT_API_KEY=YOUR_ALIENVAULT_API_KEY
SECURITYTRAILS_API_KEY=YOUR_SECURITYTRAILS_API_KEY
HUNTERIO_API_KEY=YOUR_HUNTERIO_API_KEY
LEAKLOOKUP_API_KEY=YOUR_LEAKLOOKUP_API_KEY

# Bug Bounty Platforms
HACKERONE_API_TOKEN=YOUR_HACKERONE_API_TOKEN
HACKERONE_API_URL=https://api.hackerone.com/v1
HACKERONE_USERNAME=YOUR_HACKERONE_USERNAME

# Notifications
SLACK_BOT_TOKEN=YOUR_SLACK_BOT_TOKEN
SLACK_CHANNEL=#bugbounty-approvals
SLACK_WEBHOOK_URL=YOUR_SLACK_WEBHOOK_URL

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=YOUR_EMAIL@gmail.com
SMTP_PASSWORD=YOUR_EMAIL_PASSWORD
EMAIL_FROM=noreply@bugbounty.local

# Docker
DOCKER_SOCKET=/var/run/docker.sock
PLUGIN_NETWORK=bugbounty_plugins

# Worker
WORKER_CONCURRENCY=5
WORKER_TIMEOUT=3600
